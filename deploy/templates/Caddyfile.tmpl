# ============================================================================
# Caddyfile — Skygate v0.15.0
# Generated by deploy/deploy.sh from this template + the .env.
# Output: ${DEPLOY_SKYGATE_DIR}/caddy/Caddyfile
#
# This template is the default HTTPS terminator for Skygate.
# It front-ends the skygate dashboard, the headscale admin
# API + gRPC, the headplane admin UI, and the DERP relay.
# Per-hostname routing; one Let's Encrypt cert per vhost
# (DNS-01 challenge; no port-80 inbound required).
#
# When CADDY_ENABLED=false in .env, this file is NOT
# rendered; the operator is responsible for the TLS layer
# (typical alternative: Tailscale TLS via tailscale cert,
# documented in docs/https-setup.md).
# ============================================================================

# Per-vhost shared block: compression + HSTS.
(common) {
    encode zstd gzip
    header Strict-Transport-Security "max-age=15552000; includeSubDomains; preload"
    tls {
        # DNS-01 (or HTTP-01) challenge block. The
        # deploy.sh script writes one of two variants
        # based on ${CADDY_DNS_PROVIDER}:
        #
        #   http:   just the HTTP-01 challenge
        #           (no DNS API token; port 80 must be
        #           reachable)
        #
        #   <name>: dns <name> { env.CADDY_DNS_TOKEN_VALUE }
        #           (the env var is set by deploy.sh from
        #           ${CADDY_DNS_API_TOKEN_FILE}; the
        #           rendered Caddyfile contains the variable
        #           reference, NOT the secret value)
${CADDY_TLS_DIRECTIVES}
    }
}

# ─── head (skygate dashboard + headscale API + headscale gRPC) ───
${CADDY_HOSTS_HEAD} {
    import common

    # Tailscale's control-plane protocol hits the same
    # hostname on different paths:
    #   /api/v1/*   → headscale JSON API
    #   /ts2021     → headscale gRPC-over-HTTP/2 (gRPC at
    #                the protocol level, but Tailscale
    #                wraps it in HTTP/2; Caddy passes
    #                through to the headscale gRPC
    #                listener on :50443)
    #   /machine/   → headscale gRPC-over-HTTP/2 (alt)
    #   /key        → headscale gRPC-over-HTTP/2 (alt)
    #   /oidc/*     → skygate OIDC callback (optional;
    #                only used if you set SKYGATE_OIDC_*)
    # Everything else → skygate dashboard.
    #
    # Why split by path: the headscale JSON API and
    # the skygate HTML use different routes. Mixing
    # them on one listener forces the backend to
    # disambiguate; Caddy's @matcher blocks let us
    # route at the proxy layer so each backend sees
    # only the requests it should handle.
    @headscale_api {
        path /api/*
        path /oidc/*
    }
    @headscale_grpc {
        path /ts2021/*
        path /machine/*
        path /key
    }
    reverse_proxy @headscale_api  headscale:50444
    reverse_proxy @headscale_grpc headscale:50443
    reverse_proxy                   skygate:8080
}

# ─── headplane (admin UI) ───
${CADDY_HOSTS_HEADPLANE} {
    import common
    reverse_proxy headplane:50445
}

# ─── derp (DERP relay) ───
# DERP's built-in derper does the HTTP-01 challenge
# itself, so this vhost just proxies to :443 on the
# derper container. derper-compose.yml.tmpl uses
# network_mode: host, which means from the Caddy
# container's perspective the derper is on the host's
# loopback (127.0.0.1) — UNLESS we add derper to the
# same Docker network, in which case it's reachable
# as "derper:443". The deploy.sh script sets
# ${CADDY_DERP_UPSTREAM} based on the network mode.
${CADDY_HOSTS_DERP} {
    import common
    reverse_proxy ${CADDY_DERP_UPSTREAM}
}
