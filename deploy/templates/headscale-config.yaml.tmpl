# ============================================================================
# Headscale 0.29.x configuration
# Generated by Skygate deploy system from .env.
#   Template: deploy/templates/headscale-config.yaml.tmpl
#   Rendered: deploy.sh → ${DEPLOY_HEADSCALE_DIR}/config/config.yaml
# ============================================================================

server_url: ${SKYGATE_CONTROL_URL}
listen_addr: 0.0.0.0:50444
metrics_listen_addr: 127.0.0.1:9090

tls:
  cert_path: ""
  key_path: ""

grpc_listen_addr: 0.0.0.0:50443
grpc_allow_insecure: true

noise:
  private_key_path: /etc/headscale/noise_private.key

prefixes:
  v4: 100.64.0.0/10
  v6: fd7a:115c:a1e0::/48

dns:
  magic_dns: true
  base_domain: ${HEADSCALE_BASE_DOMAIN}
  nameservers:
    global:
      - 1.1.1.1
      - 8.8.8.8

derp:
  urls:
__HEADSCALE_DERP_URLS__
  auto_update_enabled: true
  update_frequency: 24h

database:
  type: sqlite
  sqlite:
    path: /var/lib/headscale/db.sqlite

log:
  level: ${HEADSCALE_LOG_LEVEL}
  format: text

registration_mode: no_registration

policy:
  mode: database
  auto_approve:
    routes:
__HEADSCALE_AUTO_APPROVE_ROUTES__
  tag_owners:
    "tag:public":
      - ${SKYGATE_ADMIN_USER}@${HEADSCALE_BASE_DOMAIN}
    "tag:exit-node":
      - ${SKYGATE_ADMIN_USER}@${HEADSCALE_BASE_DOMAIN}
    "tag:client":
      - ${SKYGATE_ADMIN_USER}@${HEADSCALE_BASE_DOMAIN}
