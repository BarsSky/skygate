# ============================================================================
# DERP Relay — self-hosted Tailscale DERP server
# Generated by Skygate deploy system.
# Enabled only when DERP_ENABLED=true in .env
# ============================================================================
services:
  derper:
    image: ghcr.io/tailscale/derper:latest
    container_name: derper
    restart: unless-stopped
    network_mode: host
    volumes:
      - /var/lib/derper/certs:/var/lib/derper/certs
      - /var/lib/derper/derper.conf:/var/lib/derper/derper.conf:ro
    command: >
      /derper
        --hostname=${DERP_HOSTNAME}
        --certmode=letsencrypt
        --certdir=/var/lib/derper/certs
        --stun
        --a=:443
        --verify-clients=${DERP_VERIFY_CLIENTS_URL}
        --verify-clients-fail-close=true

  derpmap:
    image: python:3-alpine
    container_name: derpmap
    restart: unless-stopped
    ports:
      - "${DERP_MAP_PORT}:8765"
    volumes:
      - ./derpmap.json:/derpmap.json:ro
    entrypoint: ["python3", "-c"]
    command:
      - |
        import http.server, json, os
        MAP = json.load(open('/derpmap.json'))
        BODY = json.dumps(MAP).encode()
        class H(http.server.BaseHTTPRequestHandler):
            def do_GET(self):
                self.send_response(200)
                self.send_header('Content-Type', 'application/json')
                self.send_header('Access-Control-Allow-Origin', '*')
                self.send_header('Content-Length', str(len(BODY)))
                self.end_headers()
                self.wfile.write(BODY)
            def log_message(self, *a): pass
        http.server.HTTPServer(('0.0.0.0', 8765), H).serve_forever()
