# ============================================================================
# Headscale + Headplane docker-compose
# Generated by Skygate deploy system — do not edit manually.
# Edit .env and re-run deploy.sh to regenerate.
# ============================================================================
services:
  headscale:
    image: headscale/headscale:0.29.1
    container_name: headscale
    restart: unless-stopped
    command: serve
    ports:
      - "0.0.0.0:50444:50444"
    volumes:
      - headscale_data:/var/lib/headscale
      - ./config:/etc/headscale
    environment:
      - TZ=UTC
    networks:
      - headscale_default

  # 2026-07-14: Этап 14 v11 — Headplane is now a pinned, documented
  # optional module (see docs/headplane.md). The image tag is
  # sourced from ${HEADPLANE_IMAGE} in .env so a Skygate upgrade
  # never silently bumps a dependency. To skip the sidecar
  # entirely, set HEADPLANE_ENABLED=false (the deploy script
  # removes this block before generating the compose file).
  headplane:
    image: ${HEADPLANE_IMAGE}
    container_name: headplane
    restart: unless-stopped
    depends_on:
      - headscale
    ports:
      - "0.0.0.0:50445:50445"
    volumes:
      - ./headplane:/etc/headplane
      - headplane_data:/data
    environment:
      # Secrets injected from .env via Skygate deploy system.
      # DO NOT put real values here — edit the .env file at project root.
      - HEADPLANE_HEADSCALE__URL=${HEADPLANE_HEADSCALE__URL}
      - HEADPLANE_HEADSCALE__INSECURE=${HEADPLANE_HEADSCALE__INSECURE}
      - HEADPLANE_HEADSCALE__API_KEY=${HEADPLANE_HEADSCALE__API_KEY}
      - HEADPLANE_SERVER__HOST=${HEADPLANE_SERVER__HOST}
      - HEADPLANE_SERVER__PORT=${HEADPLANE_SERVER__PORT}
      - HEADPLANE_SERVER__COOKIE_SECURE=${HEADPLANE_SERVER__COOKIE_SECURE}
      - HEADPLANE_SERVER__COOKIE_SECRET=${HEADPLANE_SERVER__COOKIE_SECRET}
    networks:
      - headscale_default

volumes:
  headscale_data:
  headplane_data:

networks:
  headscale_default:
    name: headscale_default
    external: true
