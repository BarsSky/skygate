# ---- Build artifacts ----
# Anchored to repo root so `cmd/skygate/` (the source dir) is NOT ignored.
# Without the leading slash, `skygate` would match any path segment named
# `skygate` — including the source tree.
/skygate
/skygate.new
/skygate-*-linux-*
*.exe

# ---- Backups & patches ----
*.bak
*.bak.*
*.bak-*
*.orig
*.rej
*.tmp
*.tar
*.tar.*
*.tgz

# ---- Local-only state ----
.env
/data/
/static/
skygate.db
*.log
*.pid

# ---- Dump/experimental scripts ----
.sg_*.ps1
# One-off investigation / verify / debug / cleanup scripts
# (created during live ops, never intended to be committed).
# They live in the working tree so `ls` and `grep` find them,
# but `git add -A` and `git status` ignore them. If a script
# graduates to "kept" status (used by smoke / docs / release
# tooling), move it to scripts/ or deploy/ and re-add to
# git explicitly.
check_*.sh
verify_*.sh
test_*.sh
copy_*.sh
debug_*.sh
reset_*.sh
fix_*.sh
cleanup_*.sh
deploy_*.sh
run_*.sh
wait_*.sh
check_*.py
check_*.ps1
verify_*.py
verify_*.ps1
test_*.py
test_*.ps1
# Anything explicitly named "test_*" lives under scripts/ in the
# repo (e.g. scripts/test_check_https.py); root-level test_*.py
# is debugging scratch. The "scripts/test_*" allowance is via
# the explicit `git add` for those.
sg_*.ps1
sg_*.sh
/sg_*.html
/sg_*.txt

# ---- Editor / OS ----
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# ---- Backup output directory ----
backup/

# Hermes agent backup directories (do not commit)
.hermes-*/

# Tailscale authkey (read at runtime by entrypoint.sh if TS_AUTHKEY_FILE=...)
# Created by `docker secret create` during local bring-up; never commit.
secrets/
/secrets/
