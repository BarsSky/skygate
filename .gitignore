# ---- Build artifacts ----
# Anchored to repo root so `cmd/skygate/` (the source dir) is NOT ignored.
# Without the leading slash, `skygate` would match any path segment named
# `skygate` — including the source tree.
/skygate
/skygate.new
/skygate-*-linux-*
*.exe

# ---- Backups & patches ----
*.bak
*.bak.*
*.bak-*
*.orig
*.rej
*.tmp
*.tar
*.tar.*
*.tgz

# ---- Local-only state ----
.env
/data/
/static/
skygate.db
*.log
*.pid

# ---- Dump/experimental scripts ----
.sg_*.ps1
sg_*.ps1
sg_*.sh
/sg_*.html
/sg_*.txt

# ---- Editor / OS ----
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# ---- Backup output directory ----
backup/

# Hermes agent backup directories (do not commit)
.hermes-*/
