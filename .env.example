# ============================================================================
# Skygate Unified Environment
# ============================================================================
# cp .env.example .env  →  fill in real values  →  ./deploy/deploy.sh
#
# Generate secrets:
#   openssl rand -hex 32    # for SKYGATE_JWT_SECRET
#   openssl rand -hex 16    # for HEADPLANE_SERVER__COOKIE_SECRET
#   openssl rand -hex 32    # for DERP_PRIVATE_KEY
#
# Generate headscale API key (after headscale is running):
#   docker exec headscale headscale apikeys create --expiration 365d

# 2026-07-15: v0.12.0 — per-user headscale control plane keys
# (portal_users.headscale_api_key_enc) are encrypted with
# AES-256-GCM keyed by this 32-byte hex string. Required to
# enable multi-control-plane per portal user; leave empty
# if all users stay on the global default headscale.
# Generate: openssl rand -hex 32
SKYGATE_SECRET_KEY=

# ─── Skygate ───────────────────────────────────────────────────────────────
SKYGATE_PORT=8080
SKYGATE_DB=/data/skygate.db
SKYGATE_JWT_SECRET=<openssl rand -hex 32>
SKYGATE_ADMIN_USER=skyadmin
SKYGATE_ADMIN_PASS=<choose strong password 16+ chars>
SKYGATE_CONTROL_URL=https://head.example.com

# ─── Headscale ─────────────────────────────────────────────────────────────
HEADSCALE_URL=http://headscale:50444
HEADSCALE_API_KEY=<docker exec headscale headscale apikeys create --expiration 365d>
HEADSCALE_CONTAINER=headscale
HEADSCALE_SERVER_URL=https://head.example.com
HEADSCALE_BASE_DOMAIN=tsnet.example.com
# Comma-separated CIDRs; converted to YAML list at deploy time
HEADSCALE_AUTO_APPROVE_ROUTES=0.0.0.0/0,::/0
# Comma-separated DERP map URLs
HEADSCALE_DERP_URLS=https://controlplane.tailscale.com/derpmap/default
HEADSCALE_LOG_LEVEL=info

# ─── Headplane (optional sidecar UI) ───────────────────────────────────────
# 2026-07-14: Этап 14 v11 — Headplane is now a documented optional
# module. See docs/headplane.md for the integration contract,
# compatibility matrix, and version pin policy.
#
# To skip the Headplane sidecar entirely, set HEADPLANE_ENABLED=false
# (skips pulling the image + starting the container in
# deploy.sh). The default is true.
HEADPLANE_ENABLED=true
# Pinned to a specific release; the v0.6.3 image supports
# Headscale 0.28+ and is the latest stable as of 2026-04-09.
# See https://headplane.net/CHANGELOG for upstream releases.
HEADPLANE_IMAGE=ghcr.io/tale/headplane:0.6.3
# 2026-07-15: v0.10.12 — point Skygate at an EXISTING Headplane
# instead of starting a second sidecar. When set, deploy.sh
# skips the headplane container in docker-compose.yml and the
# /admin/acls view links to this URL instead of the local
# sidecar. Leave empty to use the bundled sidecar.
# See docs/headplane.md "Use an existing Headplane" for details.
HEADPLANE_EXTERNAL_URL=
# Env overrides use HEADPLANE_ prefix + __ for nesting.
# These override values in deploy/templates/headplane-config.yaml
HEADPLANE_HEADSCALE__URL=http://headscale:50444
HEADPLANE_HEADSCALE__INSECURE=true
HEADPLANE_HEADSCALE__API_KEY=<same as HEADSCALE_API_KEY above>
HEADPLANE_SERVER__HOST=0.0.0.0
HEADPLANE_SERVER__PORT=50445
HEADPLANE_SERVER__COOKIE_SECURE=false
HEADPLANE_SERVER__COOKIE_SECRET=<openssl rand -hex 16>

# ─── Exit Node SSH Sync ────────────────────────────────────────────────────
# Path inside skygate container to SSH private key
SKYGATE_EXIT_SSH_KEY=/home/skyadmin/.ssh/skygate_sync
# SSH targets for syncing advertised routes (hostname or IP)
SKYGATE_EXIT_SSH=root@relay-a
SKYGATE_EXIT_SSH_RELAY_B=root@relay-b
SKYGATE_EXIT_SSH_RELAY_C=root@relay-c

# ─── DERP Relay ────────────────────────────────────────────────────────────
DERP_ENABLED=false
DERP_HOSTNAME=derp.example.com
DERP_PRIVATE_KEY=<openssl rand -hex 32>
DERP_VERIFY_CLIENTS_URL=https://head.example.com
DERP_STUN_PORT=3478
DERP_HTTP_PORT=8443
DERP_MAP_PORT=8765
# 2026-07-15: v0.10.12 — comma-separated URLs of EXISTING DERP
# relays to add to headscale's derp.urls list (alongside the
# public Tailscale DERP). When set, deploy.sh skips the bundled
# derper container — only the external ones are wired in.
# Compatible with Tailscale's own headscale derp.urls format.
# See docs/derp.md "Use an existing DERP relay" for the contract.
DERP_EXTERNAL_URLS=

# ─── Deployment paths ──────────────────────────────────────────────────────
DEPLOY_HEADSCALE_DIR=/home/skyadmin/headscale
DEPLOY_SKYGATE_DIR=/home/skyadmin/skygate
DEPLOY_BACKUP_DIR=/home/skyadmin/skygate/backup
DOCKER_NETWORK=headscale_default
DOCKER_SUBNET=172.18.0.0/16
