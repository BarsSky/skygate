# =============================================================================
# Skygate configuration
# Copy this file to `.env` and fill in the values.
#
#   cp .env.example .env
#   nano .env
#
# All values are required unless marked OPTIONAL.
# =============================================================================

# --- HTTP ---
# Port Skygate listens on inside the container.
# Default: 8080. Change if you run multiple web apps on the same host.
SKYGATE_PORT=8080

# --- SQLite database ---
# Where Skygate stores users, audit log, and preauth keys.
# Default inside container: /data/skygate.db (mounted as a volume).
# For native run on Linux/macOS: /var/lib/skygate/skygate.db
# For native run on Windows:    C:\skygate\data\skygate.db
SKYGATE_DB=/data/skygate.db

# --- Headscale integration ---
# URL of the headscale REST API.
#
#   * Same-host docker compose (default):
#       http://headscale:50444
#   * Headscale on the same host but Skygate runs natively:
#       http://localhost:50444
#   * Headscale on another server (LAN):
#       http://192.168.13.69:50444
#   * Headscale on another server (Tailscale / VPN only):
#       http://100.64.0.1:50444
#   * Headscale behind a reverse proxy (HTTPS):
#       https://headscale.example.com
# --- Public control URL clients connect to ---
# URL your users enter in Tailscale app (Android: Settings → Use custom
# coordination server; CLI: --login-server=...).
#   * Production:  https://head.skynas.ru
#   * Local test:  http://192.168.13.69:50443
#   * Behind NPM:  https://head.example.com
# If empty, Skygate derives it from HEADSCALE_URL (best-effort fallback).
SKYGATE_CONTROL_URL=
HEADSCALE_URL=http://headscale:50444

# Headscale API key with full access.
#
# Generate it ONCE on the headscale host:
#   docker exec headscale headscale apikeys create --expiration 365d
# or:
#   headscale apikeys create --expiration 365d
#
# Paste ONLY the token string, no quotes, no spaces.
# Rotate annually (or immediately if leaked — see README "Безопасность").
HEADSCALE_API_KEY=

# --- JWT session signing ---
# HMAC-SHA256 secret used to sign session cookies.
#
# Generate it:
#   openssl rand -hex 32
#
# MUST be at least 32 random bytes. Never commit to git.
# Rotating this secret invalidates ALL active sessions.
SKYGATE_JWT_SECRET=

# --- Bootstrap admin (used ONLY on first start) ---
# Username of the initial admin account.
# Default: skyadmin
SKYGATE_ADMIN_USER=skyadmin

# Password for the initial admin. Used ONCE on first start to create
# the row in portal_users, then ignored.
# Choose a strong password (16+ chars, mixed case, digits, symbols).
# To change after first start: drop the user from SQLite and restart
# with a new SKYGATE_ADMIN_PASS.
SKYGATE_ADMIN_PASS=
